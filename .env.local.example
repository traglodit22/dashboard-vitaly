# =============================================================================
# ЛОКАЛЬНАЯ РАЗРАБОТКА — скопируй в .env.local
# =============================================================================

# Вариант A: своя локальная БД (рекомендуется)
#   npm run db:setup
DATABASE_URL=postgresql://dashboard:dashboard@127.0.0.1:5432/dashboard_db

# Вариант B: туннель к прод-БД (осторожно!)
#   npm run db:tunnel   # в отдельном терминале
# DATABASE_URL=postgresql://dashboard:PASSWORD@127.0.0.1:5433/dashboard_db

SESSION_SECRET=local-dev-secret-change-me
HTTPS_ONLY=false
ADMIN_EMAIL=admin@localhost

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
ANTHROPIC_API_KEY=

DOBROPOST_API_URL=https://api.dobropost.com
DOBROPOST_EMAIL=
DOBROPOST_PASSWORD=
DOBROPOST_WEBHOOK_SECRET=

# Google Cloud Storage (категории файлов с storage_type=gcs)
# GCS_PROJECT_ID=
# GCS_CLIENT_EMAIL=
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GCS_BUCKET=

# =============================================================================
# ПРОД (VPS) — файл .env на сервере, НЕ коммитить
# =============================================================================
# CRON_SECRET=<random>
# TELEGRAM_PROXY_URL=http://127.0.0.1:8118
# HTTPS_ONLY=true
