# Скопируй в deploy/deploy.env.local (не коммитится) или задай переменные в shell.
#
# DEPLOY_HOST=135.106.161.215
# DEPLOY_USER=root
# DEPLOY_KEY=/path/to/private_key   # опционально, иначе ssh-agent / ~/.ssh/id_ed25519
#
# Cloud Agent (Cursor Secrets → Runtime Secret):
# DEPLOY_SSH_PRIVATE_KEY=<приватный ключ>
# DEPLOY_HOST, DEPLOY_USER, DEPLOY_APP_DIR, DEPLOY_PORT — опционально
# DEPLOY_APP_DIR=/var/www/dashboard
# DEPLOY_PORT=22

DEPLOY_HOST=135.106.161.215
DEPLOY_USER=root
DEPLOY_APP_DIR=/var/www/dashboard
