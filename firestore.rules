rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Весь доступ к данным идёт через серверный Admin SDK (он обходит правила).
    // Прямой доступ клиентов к Firestore полностью запрещён.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
