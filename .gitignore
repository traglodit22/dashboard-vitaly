# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/uploads/*
!uploads/procurement/.gitkeep
/runtime/current
/runtime/current.new
/runtime/current.bak
.deploy.lock

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# firebase secrets — НИКОГДА не коммитить
service-account.json
*-firebase-adminsdk-*.json

# кастомный прод-бот (DeepSeek), живёт только на VPS
bot/bot.js

# typescript
*.tsbuildinfo
next-env.d.ts
.localtools/

# локальные заметки агента (секреты, доступы) — не коммитить
.local/

# claude/cursor локальные настройки
.claude/

# миграционные данные и зависимости скриптов
scripts/firestore-export/
scripts/node_modules/
